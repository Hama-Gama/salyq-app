// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ПОЛЬЗОВАТЕЛЬ ────────────────────────────────────


model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  emailVerified     DateTime?            // ← добавь это поле
  name              String?
  image             String?
  iin               String?

  // Подписка
  subscriptionType  SubType   @default(FREE)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  isManualGrant     Boolean   @default(false)
  grantNote         String?

  // Уведомления
  tgChatId          String?
  pushEnabled       Boolean   @default(false)
  language          String    @default("ru")

  // Метаданные
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Связи
  accounts          Account[]
  sessions          Session[]
  employees         Employee[]
  incomes           Income[]
  taxSnapshots      TaxSnapshot[]
  documents         Document[]
  accessGrants      AccessGrant[]
  supportTickets    SupportTicket[]
 
	@@index([email])
  @@index([subscriptionType])
  @@map("users")
}


// ─── NEXT-AUTH ТАБЛИЦЫ ───────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── СОТРУДНИКИ ──────────────────────────────────────
model Employee {
  id                String    @id @default(cuid())
  userId            String
  name              String
  salary            Decimal   @db.Decimal(15, 2)
  hiredAt           DateTime  @default(now())
  firedAt           DateTime?
  isActive          Boolean   @default(true)

  // Влияет на расчёт ИПН
  hasMzpDeduction   Boolean   @default(true)
  childrenCount     Int       @default(0)
  isPensioner       Boolean   @default(false)
  isDisabled        Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@map("employees")
}

// ─── ДОХОДЫ ──────────────────────────────────────────
model Income {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @default(now())
  category    String?
  note        String?
  isOffline   Boolean  @default(false)

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([userId])
  @@index([userId, date])
  @@index([date])
  @@map("incomes")
}

// ─── НАЛОГОВЫЕ ПЕРИОДЫ ───────────────────────────────
model TaxSnapshot {
  id                  String        @id @default(cuid())
  userId              String
  periodYear          Int
  periodHalf          Int
  totalIncome         Decimal       @db.Decimal(15, 2)
  totalTaxEstimated   Decimal       @db.Decimal(15, 2)
  status              PaymentStatus @default(PENDING)

  limitWarning85Sent  Boolean       @default(false)
  limitWarning95Sent  Boolean       @default(false)
  ndsWarningSent      Boolean       @default(false)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodYear, periodHalf])
  @@index([userId])
	@@index([userId, periodYear])
  @@map("tax_snapshots")
}

// ─── ДОКУМЕНТЫ (PDF) ─────────────────────────────────
model Document {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  fileUrl     String
  fileSize    Int?
  docType     DocType
  period      String?

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
	@@index([userId, docType])
  @@map("documents")
}

// ─── ГРАНТЫ ДОСТУПА ──────────────────────────────────
model AccessGrant {
  id          String    @id @default(cuid())
  userId      String
  grantedBy   String
  type        String
  months      Int?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  note        String?

  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])
  @@index([endDate])
  @@map("access_grants")
}

// ─── ПРОМОКОДЫ ───────────────────────────────────────
model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  months      Int
  maxUses     Int
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())

  @@map("promo_codes")
}

// ─── ТИКЕТЫ ПОДДЕРЖКИ ────────────────────────────────
model SupportTicket {
  id        String        @id @default(cuid())
  userId    String
  type      TicketType
  subject   String
  message   String
  status    TicketStatus  @default(OPEN)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

// ─── ENUMS ───────────────────────────────────────────
enum SubType {
  FREE
  PRO
  BUSINESS
  MANUAL_GRANT
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocType {
  RECEIPT
  REPORT
  TAX_RETURN
}

enum TicketType {
  BUG
  FEATURE
  TAX_HELP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}